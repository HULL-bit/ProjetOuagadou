# Configuration Supabase pour Pirogue Connect
# Copiez ce fichier vers .env.local et remplissez avec vos vraies valeurs

# URL de votre projet Supabase
VITE_SUPABASE_URL=https://votre-projet-id.supabase.co

# Clé publique anonyme de Supabase
VITE_SUPABASE_ANON_KEY=votre-cle-anon-ici

# Variables optionnelles
VITE_APP_NAME=Pirogue Connect
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=development

# Mode démo (true pour utiliser les données simulées)
VITE_DEMO_MODE=false