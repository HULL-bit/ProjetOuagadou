# Configuration Django pour PIROGUE-SMART
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL
DB_NAME=pirogue_smart
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# Redis pour Celery et Channels
REDIS_URL=redis://localhost:6379

# API Keys (à configurer selon vos besoins)
WEATHER_API_KEY=your-weather-api-key
TRACKER_API_KEY=your-tracker-api-key
TRACKER_API_URL=your-tracker-api-url

# Email configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password